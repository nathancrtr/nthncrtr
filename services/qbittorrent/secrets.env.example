# Proton VPN WireGuard credentials for the gluetun sidecar.
#
# Copy to /srv/qbittorrent/secrets.env on natto (owner root:root, mode 0600)
# and populate with values from the WireGuard config downloaded from the
# Proton VPN dashboard. The WireGuard config MUST be generated with
# "Port Forwarding" enabled — otherwise inbound peer connections for private
# trackers won't work.
#
# VPN_PORT_FORWARDING=on actually enables the forwarding (Gluetun asks the
# provider for a port). PORT_FORWARD_ONLY=on is a *server filter* — it
# restricts Gluetun to servers that support PF, so reconnects don't land on
# a server that drops the forwarded port. Set both.

VPN_TYPE=wireguard
VPN_SERVICE_PROVIDER=protonvpn

# From the [Interface] PrivateKey line of the downloaded wg config.
WIREGUARD_PRIVATE_KEY=

# From the [Interface] Address line. Typically a /32 like 10.2.0.2/32.
WIREGUARD_ADDRESSES=

# Comma-separated country names (Gluetun matches against its server list).
# Switzerland is the default for this deployment; Netherlands is another
# privacy-friendly option.
SERVER_COUNTRIES=Switzerland

# Port forwarding toggles. Both should be on for Proton + private trackers.
VPN_PORT_FORWARDING=on
PORT_FORWARD_ONLY=on
