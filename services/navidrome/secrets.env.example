# Copy to /srv/navidrome/secrets.env on natto, populate, chmod 0600.
# Navidrome reads this via docker-compose's env_file directive.
#
# DO NOT COMMIT THE POPULATED VERSION.

# Encrypts user passwords at rest in navidrome.db. Generate with:
#   openssl rand -hex 32
#
# WARNING: this key is NOT recoverable. If it is lost or changed, every
# user password becomes undecryptable and EVERYONE is locked out (recovery
# = the plaintext-write + restart procedure in README.md § Password
# encryption). It rides along in the nightly /srv backup tarball, so a
# backup restore brings it back — but a from-scratch natto rebuild without
# a backup restore loses it. NOTE: setting this key does NOT auto-encrypt
# pre-existing plaintext passwords (Navidrome's migration is key-rotation
# only) — see README.md § Password encryption / Recovery for the
# scratch-instance transplant that actually does it.
ND_PASSWORDENCRYPTIONKEY=

# Last.fm scrobbling. Server-wide app credentials; obtain by registering
# an app at https://www.last.fm/api/account/create (one-time). Each user
# then links their own last.fm account in Navidrome's profile UI.
# See README.md § Last.fm scrobbling.
ND_LASTFM_APIKEY=
ND_LASTFM_SECRET=
