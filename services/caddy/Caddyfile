}

# Subtitle downloader (feeds SRTs to the Sonarr/Radarr libraries so video
# direct-plays with subtitles instead of forcing a burn-in transcode).
# Web-admin tier like the *arrs: Authelia + 127.0.0.1-only publish.
bazarr.nthncrtr.com {
	import authelia
	reverse_proxy 127.0.0.1:6767
}

# Coffee roasting app — roaster-web on kvass:8080 (kvass = 100.65.46.92,
# stable per-node Tailscale IP; see the header note on why not the name).
starmaya.nthncrtr.com {
	reverse_proxy 100.65.46.92:8080
}

# Immich — self-hosted photo/video backup (Google Photos replacement).
# Tailnet-only like Nextcloud: this name resolves (via Cloudflare DNS) to
# natto's Tailscale IP, so it is NOT internet-exposed (Jellyfin remains the
# only public service — safety rule 8; Immich is not on the Cloudflare
# Tunnel). Deliberately NO `import authelia`: Immich's native mobile app
# (the primary auto-backup path) breaks behind forward_auth, same as
# Jellyfin's native clients (WORKLIST 6.4/6.6). The gate is tailnet-only
# reach + Immich's own per-user accounts. See services/immich/README.md.
photos.nthncrtr.com {
	reverse_proxy 127.0.0.1:2283
}

# Memos — lightweight self-hosted note-taking / quick-capture. Tailnet-only
# like Nextcloud/Immich: this name resolves (via Cloudflare DNS) to natto's
# Tailscale IP, so it is NOT internet-exposed (Jellyfin + Seerr remain the
# only public services — safety rule 8; Memos is not on the Cloudflare
# Tunnel). Deliberately NO `import authelia`: Memos ships native mobile apps
# that break behind forward_auth, same as Jellyfin/Seerr/Immich. The gate is
# tailnet-only reach + Memos' own per-user accounts. See services/memos/README.md.
notes.nthncrtr.com {
	reverse_proxy 127.0.0.1:5230
}

# Jellyfin — the ONE internet-exposed service (operator decision, WORKLIST
# 6.6). This block is the INSIDE-ONLY path. Read before touching:
#
#  - PUBLIC ingress is NOT here: it's a Cloudflare Tunnel
#    (services/cloudflared) — cloudflared dials out and maps
#    play.nthncrtr.com → Jellyfin directly. Caddy is deliberately NOT in
#    the public path (GFiber can't port-forward — reserved 443 /
#    phantom-device / DMZ=all; full saga in services/jellyfin/README.md).
#  - This `play.nthncrtr.com` block exists so INSIDE/LAN clients reach
#    Jellyfin by the same hostname without a Cloudflare round-trip:
#    Pi-hole split-horizon points play.nthncrtr.com at natto's LAN IP →
#    this :443 site → Jellyfin. One PublishedServerUrl
#    (https://play.nthncrtr.com, no port) works in (here) and out (tunnel).
#  - It is :443-implicit like every other vhost — NOT a router-forward
#    target, nothing here is reachable from the internet (the tunnel is).
#    An explicit host:443 site is more specific than the `:443 { abort }`
#    catch-all below, so only THIS host is served; the catch-all still
#    swallows every other name.
#  - NO `import authelia`: forward_auth breaks Jellyfin's native TV/phone
#    clients (WORKLIST 6.4/6.6). The gate is Jellyfin's own per-user
#    accounts + a Cloudflare WAF Rate-Limiting rule on the login path
#    (dashboard config — see WORKLIST 6.6).
#  - Name is "play", NOT "jellyfin", on purpose: `jellyfin.*` is exactly
#    what automated Jellyfin-CVE scanners enumerate. Do NOT rename it.
play.nthncrtr.com {
	reverse_proxy 127.0.0.1:8096
}

# Seerr — request manager paired with Jellyfin (services/seerr). Like
# play. above, this block is the INSIDE-ONLY path; the public ingress is
# the same Cloudflare Tunnel (services/cloudflared), with
# requests.nthncrtr.com → Seerr added to the tunnel's ingress allowlist.
# NO `import authelia`: Seerr ships a native mobile app and forward_auth
# would break it, same reasoning as Jellyfin/Immich. The gate is Jellyfin
# SSO + a Cloudflare WAF Rate-Limiting rule on /api/v1/auth/jellyfin
# (dashboard state, not in repo). See services/seerr/README.md.
requests.nthncrtr.com {
	reverse_proxy 127.0.0.1:5055
}

:443 {
	abort
}
