# Immich database credentials.
#
# Copy to /srv/immich/secrets.env on natto (owner root:root, mode 0600) and
# fill in the blanks. This one file is loaded by BOTH immich-server and
# immich-db (the unused vars in each are harmless).
#
# DB_PASSWORD is the connection secret immich-server uses; POSTGRES_PASSWORD
# is what the postgres image initializes the superuser with on first run.
# THEY MUST BE THE SAME VALUE — if they drift, immich-server can't connect.
#
# Generate with: openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 32
# (Immich requires only A-Za-z0-9 in DB_PASSWORD — no special chars/spaces.)
# POSTGRES_PASSWORD is only read on the very first DB init; changing it later
# requires an ALTER USER inside the running postgres, not just an edit here.

DB_PASSWORD=
POSTGRES_PASSWORD=
