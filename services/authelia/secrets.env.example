# Authelia runtime secrets.
#
# Copy to /srv/authelia/secrets.env on natto (owner root:root, mode 0600)
# and fill in the blanks. Loaded by the authelia container via env_file.
# These three values are what Authelia would otherwise read from
# configuration.yml — they are kept out of the repo and injected here.
#
# Generate each value (independent random strings, do NOT reuse):
#
#   docker run --rm authelia/authelia:4.39 authelia crypto rand --length 64 --charset alphanumeric
#
# (run three times, one per variable). Rotating SESSION_SECRET logs everyone
# out; rotating STORAGE_ENCRYPTION_KEY requires
# `authelia storage encryption change-key` against the sqlite db — do not
# change it casually once data exists.

AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=
