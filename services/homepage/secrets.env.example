# Copy to /srv/homepage/secrets.env on natto, populate with real values,
# chmod 0600. The Homepage container reads this via docker-compose's
# env_file directive; values become available to services.yaml as
# {{HOMEPAGE_VAR_*}} substitutions.
#
# DO NOT COMMIT THE POPULATED VERSION.

HOMEPAGE_VAR_PIHOLE_KEY=
HOMEPAGE_VAR_NAVIDROME_TOKEN=
HOMEPAGE_VAR_NAVIDROME_SALT=

# Set when qBittorrent is deployed:
HOMEPAGE_VAR_QBITTORRENT_PASSWORD=

# Set when Radarr is deployed (Settings → General → Security → API Key):
HOMEPAGE_VAR_RADARR_KEY=

# Set when Sonarr is deployed (Settings → General → Security → API Key):
HOMEPAGE_VAR_SONARR_KEY=

# Set when Prowlarr is deployed (Settings → General → Security → API Key):
HOMEPAGE_VAR_PROWLARR_KEY=

# Nextcloud serverinfo widget. Use a Nextcloud APP PASSWORD, not the admin
# login password: in Nextcloud, log in as nthncrtr → Settings → Security →
# "Devices & sessions" → create app password (name it e.g. "homepage").
HOMEPAGE_VAR_NEXTCLOUD_PASSWORD=

# Jellyfin widget API key: Jellyfin → Dashboard → API Keys → "+" (name it
# e.g. "homepage").
HOMEPAGE_VAR_JELLYFIN_KEY=
