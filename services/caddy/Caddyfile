{
	# Use DNS-01 challenge via Cloudflare for all sites
	acme_dns cloudflare {env.CF_API_TOKEN}
}

# Proxy upstreams are addressed by IP, never by a tailnet (MagicDNS) name:
#  - Colocated services use 127.0.0.1 (their compose files publish on
#    0.0.0.0:<port>). A host-tailnet-name self-reference silently 502s on any
#    tailnet identity change (the 2026-05 Pi->Beelink migration joined as
#    `natto-1`).
#  - The one remote upstream (starmaya -> kvass) uses kvass's stable Tailscale
#    IP, NOT kvass.tailaf7ea6.ts.net: this host runs Pi-hole on :53, so
#    systemd-resolved's stub is disabled and MagicDNS does not resolve here.
#    Tailnet *connectivity* to that IP is fine (tailscale ping kvass: ~8ms).

# SSO gate for the web-admin tier. Authelia runs as a Docker container
# published on 127.0.0.1:9091 (deploy.sh authelia — opt-in). Caddy is native
# on natto so 127.0.0.1 reaches it. Any site that `import authelia`s requires
# an Authelia session; unauthenticated requests are 302'd to the portal.
# Authelia MUST be up before this config is reloaded or the gated sites 502
# — deploy order is `deploy.sh authelia` then `deploy.sh caddy`.
(authelia) {
	forward_auth 127.0.0.1:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

# SSO portal (NOT itself behind the gate — that would be a redirect loop).
auth.nthncrtr.com {
	reverse_proxy 127.0.0.1:9091
}

# Dashboard
home.nthncrtr.com {
	import authelia
	reverse_proxy 127.0.0.1:3000
}

# Music
natto.nthncrtr.com {
	reverse_proxy 127.0.0.1:4533
}

# Pi-hole admin
pi-hole.nthncrtr.com {
	reverse_proxy 127.0.0.1:8053
}

# Torrent client
torrent.nthncrtr.com {
	import authelia
	reverse_proxy 127.0.0.1:8080
}

# Movies
radarr.nthncrtr.com {
	import authelia
	reverse_proxy 127.0.0.1:7878
}

# TV series
sonarr.nthncrtr.com {
	import authelia
	reverse_proxy 127.0.0.1:8989
}

# Indexer manager
prowlarr.nthncrtr.com {
	import authelia
	reverse_proxy 127.0.0.1:9696
}

# Coffee roasting app — roaster-web on kvass:8080 (kvass = 100.65.46.92,
# stable per-node Tailscale IP; see the header note on why not the name).
starmaya.nthncrtr.com {
	reverse_proxy 100.65.46.92:8080
}

:443 {
	abort
}
