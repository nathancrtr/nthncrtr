# Copy to action.d/cloudflare-token.local on natto
# (/srv/fail2ban/config/fail2ban/action.d/cloudflare-token.local), fill
# both values, chmod 0600. fail2ban auto-merges *.local OVER the stock
# *.conf, so this only supplies the secret + zone — it does not redefine
# the action. DO NOT COMMIT THE FILLED VERSION (.gitignore excludes *.local
# and credentials.json).
#
# Verified against the image's shipped action (do not assume — re-check on
# upgrade):  docker exec fail2ban cat /etc/fail2ban/action.d/cloudflare-token.conf
# It calls:  POST/GET https://api.cloudflare.com/client/v4/zones/<cfzone>/firewall/access_rules/rules
#            -H "Authorization: Bearer <cftoken>"
# So it needs the zone-level IP Access Rules API → BOTH params below.
#
# cftoken — Cloudflare API token. dash.cloudflare.com → My Profile → API
#   Tokens → Create Token → Custom token. Scope (minimal):
#     Zone → Firewall Services → Edit     on Specific zone → nthncrtr.com
#   (This is the "IP Access Rules" permission. NOT Account Filter Lists —
#   that's a different, account-level API this action does not use.)
# cfzone — the Zone ID for nthncrtr.com: Cloudflare dashboard → nthncrtr.com
#   → Overview → right column "Zone ID" (a 32-hex string). It is NOT a
#   secret but is required by the action's URL.

[Init]
cftoken =
cfzone =
