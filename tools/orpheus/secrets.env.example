# Copy to secrets.env (gitignored) and fill in.

# Generate at https://orpheus.network/user.php?action=edit → "Access Settings" → "Create an API Key".
# Minimum scopes: Torrents (read). User scope optional. Upload scope needed for the upload pipeline.
OPS_API_KEY=

# Per-user tracker announce URL containing your passkey. Get it from any .torrent
# you've downloaded from OPS, or from your profile's "Personal Announce URL".
# Format: https://home.opsfet.ch/<passkey>/announce
OPS_ANNOUNCE_URL=

# Cloudflare R2 (S3-compatible object storage) — used by art_upload.py to host
# album cover art for OPS group pages. Catbox.moe was unreliable (covers
# rendered as broken images on ~75% of our uploads); R2 with a custom domain
# gives us permanent URLs we control.
#
# Setup:
#   1. Cloudflare dashboard → R2 → Create bucket `nthncrtr-covers`
#   2. Bucket → Settings → Public access → Connect domain → covers.nthncrtr.com
#   3. R2 → Manage API Tokens → Create token (Object Read+Write on the bucket)
#   4. Account ID is visible in the R2 dashboard URL
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nthncrtr-covers
R2_PUBLIC_BASE=https://covers.nthncrtr.com
