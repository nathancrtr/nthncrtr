{
	# Use DNS-01 challenge via Cloudflare for all sites
	acme_dns cloudflare {env.CF_API_TOKEN}
}

# Colocated services are proxied via 127.0.0.1 (their compose files publish on
# 0.0.0.0:<port>). Do NOT use the host's own tailnet name here: a tailnet
# identity change (e.g. the 2026-05 Pi->Beelink migration, which joined as
# `natto-1`) silently 502s every such upstream. Only genuinely remote
# upstreams (starmaya -> kvass) use a tailnet name.

# Dashboard
home.nthncrtr.com {
	reverse_proxy 127.0.0.1:3000
}

# Music
natto.nthncrtr.com {
	reverse_proxy 127.0.0.1:4533
}

# Pi-hole admin
pi-hole.nthncrtr.com {
	reverse_proxy 127.0.0.1:8053
}

# Torrent client
torrent.nthncrtr.com {
	reverse_proxy 127.0.0.1:8080
}

# Movies
radarr.nthncrtr.com {
	reverse_proxy 127.0.0.1:7878
}

# TV series
sonarr.nthncrtr.com {
	reverse_proxy 127.0.0.1:8989
}

# Indexer manager
prowlarr.nthncrtr.com {
	reverse_proxy 127.0.0.1:9696
}

# Coffee roasting app — roaster-web on kvass:8080.
starmaya.nthncrtr.com {
	reverse_proxy kvass.tailaf7ea6.ts.net:8080
}

:443 {
	abort
}
