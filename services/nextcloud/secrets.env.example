# Nextcloud + MariaDB credentials.
#
# Copy to /srv/nextcloud/secrets.env on natto (owner root:root, mode 0600)
# and fill in the blanks. This one file is loaded by BOTH the nextcloud-db
# and nextcloud containers (the unused vars in each are harmless).
#
# The MariaDB image honors the legacy MYSQL_* names, and the Nextcloud image
# reads the same MYSQL_* set to auto-configure its DB connection on first
# run — so a single set of variables wires up both.
#
# Generate the passwords with e.g. `openssl rand -base64 24`. The admin
# user/password create the first Nextcloud account on initial startup; you
# can change the password from the web UI afterward (this var is only read
# on the very first install).

# --- database ---
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud

# --- first Nextcloud admin account (read only on initial install) ---
NEXTCLOUD_ADMIN_USER=
NEXTCLOUD_ADMIN_PASSWORD=
